# Supabase (Authentication, optional backend)
# Pobierz z: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# Storage: bucket w Dashboard (np. product-images, public). Polityki — plik supabase/storage-product-images.sql
SUPABASE_STORAGE_PRODUCT_BUCKET=product-images
# Opcjonalnie limit rozmiaru pliku (bajty), domyślnie 5242880 (5 MB)
# SUPABASE_STORAGE_PRODUCT_IMAGE_MAX_BYTES=5242880

NUXT_PUBLIC_API_BASE=